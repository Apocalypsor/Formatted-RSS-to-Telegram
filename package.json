{
  "name": "formatted-rss-to-telegram",
  "version": "0.0.1",
  "description": "A highly customizable, self-hosted RSS to Telegram notification service",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "NODE_ENV=development bun --watch ./src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "check": "biome check --no-errors-on-unmatched --files-ignore-unknown=true --write",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apocalypsor/Formatted-RSS-to-Telegram.git"
  },
  "author": "Apocalypsor",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Apocalypsor/Formatted-RSS-to-Telegram/issues"
  },
  "homepage": "https://github.com/Apocalypsor/Formatted-RSS-to-Telegram#readme",
  "dependencies": {
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "ky": "^1.14.3",
    "lodash-es": "^4.17.23",
    "node-schedule": "^2.1.1",
    "nunjucks": "^3.2.4",
    "p-queue": "^9.1.0",
    "rss-parser": "^3.13.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^4.7.1",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/bun": "latest",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.15",
    "@types/node-schedule": "^2.1.8",
    "@types/nunjucks": "^3.2.6",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  }
}
